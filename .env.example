# Local / docker-compose Mongo (same DB name)
# - Host app (`npm run dev`): mongodb://127.0.0.1:27017/vm-to-model
# - App container: set automatically to mongodb://mongo:27017/vm-to-model
MONGODB_URI=mongodb://127.0.0.1:27017/vm-to-model

# Public base URL used in email submit links (optional; request origin used as fallback)
APP_BASE_URL=https://submit.aaptor.com

# ZeptoMail (Zoho) — Send Mail API token
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=info@aaptor.com
ZEPTOMAIL_FROM_NAME=Aaptor
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
NOTIFICATION_EMAIL=info@aaptor.com

# Model scoring — async project eval (no API key / org headers)
# HOST examples: https://model.aaptor.com  or  http://127.0.0.1:7000
# POST /api/v1/evaluation/project/async → poll GET /api/v1/job/{job_id}
MODEL_API_URL=https://model.aaptor.com
MODEL_POLL_INTERVAL_MS=2500
MODEL_POLL_TIMEOUT_MS=600000
# MODEL_SCORING_DISABLED=1
MAX_ZIP_BYTES=26214400
